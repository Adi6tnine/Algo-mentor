# Database Configuration
DATABASE_NAME=algomentor
DATABASE_USERNAME=algomentor_user
DATABASE_PASSWORD=your_secure_password_here
DATABASE_PORT=5432

# JWT Configuration (CRITICAL: Generate a secure random key for production)
# Generate using: openssl rand -base64 64
JWT_SECRET=mySecretKeyForJwtTokenGenerationThatIsAtLeast256BitsLongForHS256Algorithm
JWT_EXPIRATION=18000000

# CORS Configuration (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=60000

# Server Ports
BACKEND_PORT=8080
FRONTEND_PORT=80

# Frontend API URL
REACT_APP_API_URL=http://localhost:8080/api/v1

# Spring Profile (dev or prod)
SPRING_PROFILES_ACTIVE=dev

